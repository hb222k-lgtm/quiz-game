rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 참가자: 본인 문서만 수정 가능, 읽기는 모두 허용 (리더보드용)
    match /participants/{nickname} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }

    // 장소: 읽기만 허용 (수정은 Firebase 콘솔 또는 관리자 앱에서)
    match /locations/{locationId} {
      allow read: if true;
      allow write: if true;  // 배포 후 관리자 인증 추가 권장
    }

    // QR 코드: 읽기/쓰기 허용 (스캔 기록 업데이트용)
    match /qrcodes/{qrId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
